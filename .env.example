# Local Postgres
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=dnd
DB_PORT=5432
# Used when running `bun run dev` natively (outside Docker). When running via
# `docker compose up`, the app container overrides this to point at the `db`
# service instead of localhost — see docker-compose.yaml.
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/dnd"

# Neon Cloud provider setup (Admin only) — create .env.production and put the url there:
# DATABASE_URL="postgresql://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require"
